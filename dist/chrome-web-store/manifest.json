{
  "manifest_version": 3,
  "name": "Cathay Award Flight Finder",
  "version": "2026.7.15",
  "description": "Adds an award flight finder panel to Cathay Pacific booking pages.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Cathay Award Flight Finder",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.cathaypacific.com/*",
        "https://book.cathaypacific.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "host_permissions": [
    "https://*.cathaypacific.com/*",
    "https://book.cathaypacific.com/*"
  ]
}
